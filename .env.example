# ===========================================
# OPPTRA AI E-COMMERCE PLATFORM - ENV CONFIG
# ===========================================
# Copy this file to .env and fill in your values

# Supabase Configuration (REQUIRED - FREE)
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For server-side operations (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (optional, defaults to current origin)
VITE_SITE_URL=http://localhost:5173

# Anthropic Claude API (OPTIONAL - for AI features)
# Get free trial at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Sheets API (OPTIONAL)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=your-google-api-key
GOOGLE_SHEET_ID=your-spreadsheet-id

# Notion API (OPTIONAL)
# Create integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your-notion-token
NOTION_DATABASE_ID=your-database-id

# Development
NODE_ENV=development
