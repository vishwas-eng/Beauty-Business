{
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "api/**/*.ts",
    "src/lib/agent.ts",
    "src/lib/beautyTracker.ts",
    "src/lib/liveSnapshot.ts",
    "src/types/**/*.ts"
  ]
}
